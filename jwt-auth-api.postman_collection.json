{
  "info": {
    "name": "JWT Auth API",
    "description": "Full collection for testing the JWT Auth REST API. Import this into Postman and run Register first, then Login — tokens are saved automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"rahil@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "description": "Register a new user. Returns user id, email, and createdAt."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
              "pm.test(\"Success is true\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"abc@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "description": "Login with email and password. Access token and refresh token are auto-saved to collection variables."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "",
              "const json = pm.response.json();",
              "",
              "if (json.accessToken) {",
              "  pm.collectionVariables.set(\"accessToken\", json.accessToken);",
              "  console.log(\"✅ accessToken saved\");",
              "}",
              "",
              "if (json.refreshToken) {",
              "  pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
              "  console.log(\"✅ refreshToken saved\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3 - Get Me (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "me"]
        },
        "description": "Get the currently logged-in user's info. Requires a valid access token (auto-filled after Login)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Has user object\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.user).to.be.an('object');",
              "  pm.expect(json.user).to.have.property('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4 - Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "description": "Get a new access token using the refresh token. New tokens are auto-saved."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "",
              "const json = pm.response.json();",
              "",
              "if (json.accessToken) {",
              "  pm.collectionVariables.set(\"accessToken\", json.accessToken);",
              "  console.log(\"✅ new accessToken saved\");",
              "}",
              "",
              "if (json.refreshToken) {",
              "  pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
              "  console.log(\"✅ new refreshToken saved\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5 - Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "description": "Logout the user by invalidating their refresh token in Redis."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Logged out\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.success).to.be.true;",
              "});",
              "",
              "// Clear saved tokens after logout",
              "pm.collectionVariables.set(\"accessToken\", \"\");",
              "pm.collectionVariables.set(\"refreshToken\", \"\");",
              "console.log(\"🗑️ Tokens cleared\");"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
